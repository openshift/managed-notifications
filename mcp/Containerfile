# Alternative Containerfile that downloads model and builds embeddings at runtime
# This reduces image size significantly but adds 2-5 minutes to startup time

FROM registry.access.redhat.com/ubi10/ubi-minimal:latest

# Install Python 3 and required packages
RUN microdnf install -y python3 python3-pip python3-devel gcc util-linux && \
    microdnf clean all

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Set working directory
WORKDIR /app
ENV UV_NO_CACHE=1

# Copy all source files
COPY mcp/pyproject.toml ./
COPY mcp/uv.lock ./

# Install dependencies with CPU-only PyTorch
RUN uv sync --no-dev && \
    uv pip install --index-url https://download.pytorch.org/whl/cpu torch torchvision torchaudio --force-reinstall

# Copy notification templates and scripts (embeddings built at runtime)
COPY mcp/scripts/ ./scripts/
# Copy all notification directories to create the expected managed-notifications structure
COPY cluster ./managed-notifications/cluster/
COPY hcp ./managed-notifications/hcp/
COPY osd ./managed-notifications/osd/
COPY rosa ./managed-notifications/rosa/
COPY ocm ./managed-notifications/ocm/

# Set environment variables for MCP server
ENV HOST=0.0.0.0
ENV PORT=8000
ENV HF_HOME=/tmp/huggingface
ENV TRANSFORMERS_CACHE=/tmp/huggingface
ENV CHROMA_DB_PATH=/tmp/chroma_db

# Copy mcp server code and startup script
COPY mcp/main.py ./
COPY mcp/start.sh ./

# Expose port for MCP server
EXPOSE 8000

# Default command
CMD ["./start.sh"]
